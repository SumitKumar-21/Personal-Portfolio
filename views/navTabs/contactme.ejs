<% layout("./layouts/boilerplate") %>

<section class="contact-section">

    <div class="contact-container">

        <!-- LEFT SIDE -->
        <div class="contact-info">
            <h1>Get In <span>Touch.</span></h1>

            <p class="contact-description">
              I'm always open to
                connect and discuss interesting opportunities.
            </p>

            <div class="availability">
                <span class="status-dot"></span>
                Open to internships & collaborations
            </div>

            <div class="contact-direct">

                <p>Prefer reaching out directly?</p>
                <a href="https://www.linkedin.com/in/sumit-kumar-sah-6586a1369" target="_blank">
                  
            <i class="devicon-linkedin-plain colored" style="font-size: 35px;"></i>
          
                </a>

            </div>

        </div>


        <!-- RIGHT SIDE -->

        <div class="contact-form-container">

            <form id="contact-form" action="/contactme" method="post">

                <input
                    type="hidden"
                    name="message[time]"
                    id="timeField"
                >


                <div class="form-group">

                    <label for="name">Name</label>

                    <input
                        id="name"
                        type="text"
                        name="message[name]"
                        placeholder="Your name"
                        required
                    >

                </div>


                <div class="form-group">

                    <label for="email">Email</label>

                    <input
                        id="email"
                        type="email"
                        name="message[email]"
                        placeholder="you@example.com"
                        required
                    >

                </div>


                <div class="form-group">

                    <label for="message">Message</label>

                    <textarea
                        id="message"
                        name="message[message]"
                        placeholder="Leave a short message, whatever you have in your mind..."
                        rows="6"
                        required
                    ></textarea>

                </div>


                <button class="contact-btn" type="submit">

                    Send Message

                    <span>→</span>

                </button>


                <p class="privacy-text">
                    I won't share your email with anyone.
                </p>

            </form>

        </div>

    </div>

</section>