<% layout('/layouts/boilerplate') %>

<a class="btn btn-dark ms-0 mt-1 admin-back-link" href="/admin/dashboard" role="button">
  <i class="fa-solid fa-arrow-left bg-transparent fs-6 me-1"></i>
  Back
</a>
  <div class="container admin-project-form-page d-flex justify-content-center align-items-center min-vh-100 py-5">
    <div class="card admin-project-card col-12 col-md-10 col-lg-8">
      <div class="card-header admin-project-card-header text-center">
        <span class="admin-form-kicker">Project Manager</span>
        <h2 class="bg-transparent fw-bold mb-0 py-2 fs-3 fs-md-2">Add new Project Details</h2>
      </div>
      <div class="card-body admin-project-card-body p-4">
        <form action="/admin/addProject" method="post" class="needs-validation admin-project-form" novalidate enctype="multipart/form-data">
          
          <!-- Title -->
          <div class="mb-4 row align-items-center">
            <label class="form-label col-12 col-sm-3 fw-bold text-sm-end mb-1 mb-sm-0">Title:</label>
            <div class="col-12 col-sm-9">
              <input class="form-control" type="text" name="project[title]" required>
              <div class="invalid-feedback">⚠️ Title is required</div>
            </div>
          </div>

          <!-- Description -->
          <div class="mb-4 row align-items-center">
            <label class="form-label col-12 col-sm-3 fw-bold text-sm-end mb-1 mb-sm-0">Short Description:</label>
            <div class="col-12 col-sm-9">
              <textarea class="form-control" rows="3" name="project[shortDescription]" required></textarea>
              <div class="invalid-feedback">⚠️required</div>
            </div>
          </div>

          <div class="mb-4 row align-items-center">
            <label class="form-label col-12 col-sm-3 fw-bold text-sm-end mb-1 mb-sm-0">Full Description:</label>
            <div class="col-12 col-sm-9">
              <textarea class="form-control" rows="3" name="project[description]" required></textarea>
              <div class="invalid-feedback">⚠️ Description required</div>
            </div>
          </div>

          <div class="mb-4 row align-items-center">
            <label class="form-label col-12 col-sm-3 fw-bold text-sm-end mb-1 mb-sm-0">Purpose:</label>
            <div class="col-12 col-sm-9">
              <textarea class="form-control" rows="3" name="project[purpose]"></textarea>
            </div>
          </div>

          <div class="mb-4 row align-items-center">
            <label class="form-label col-12 col-sm-3 fw-bold text-sm-end mb-1 mb-sm-0">Learning:</label>
            <div class="col-12 col-sm-9">
              <textarea class="form-control" rows="3" name="project[learning]"></textarea>
            </div>
          </div>
          <div class="mb-4 row align-items-center">
            <label class="form-label col-12 col-sm-3 fw-bold text-sm-end mb-1 mb-sm-0">Ai Contribution:</label>
            <div class="col-12 col-sm-9">
              <textarea class="form-control" rows="3" name="project[aiRole]"></textarea>
            </div>
          </div>

          <!-- Image Upload -->
          <div class="mb-4 row align-items-center">
            <label class="form-label col-12 col-sm-3 fw-bold text-sm-end mb-1 mb-sm-0">Thumbnail:</label>
            <div class="col-12 col-sm-9">
              <input type="file" class="form-control" name="project[thumbnail]" required >
              <div class="invalid-feedback">⚠️ Please upload thumbnail</div>
            </div>
          </div>
          <!-- Links -->
          <div class="mb-4 row g-3">
            <div class="col-12 col-md-6 row align-items-center mx-0 px-0">
              <label class="form-label col-12 col-sm-3 fw-bold text-md-end mb-1 mb-sm-0">Live Demo:</label>
              <div class="col-12 col-sm-9">
                <input class="form-control" type="text" name="project[iframeUrl]" required>
                <div class="invalid-feedback">⚠️Links required</div>
              </div>
            </div>
            <div class="col-12 col-md-6 row align-items-center mx-0 px-0">
              <label class="form-label col-12 col-sm-3 fw-bold text-md-end mb-1 mb-sm-0">Github Link:</label>
              <div class="col-12 col-sm-9">
                <input class="form-control" type="text" name="project[githubLink]" required>
                <div class="invalid-feedback">⚠️Github Link required</div>
              </div>
            </div>
          </div>
           <!-- Date -->
           <div class="mb-4 row g-3">
            <div class="col-12 col-md-6 row align-items-center mx-0 px-0">
              <label class="form-label col-12 col-sm-3 fw-bold text-md-end mb-1 mb-sm-0">Date:</label>
              <div class="col-12 col-sm-9">
                <input class="form-control" type="date" name="project[date]">
              </div>
            </div>

             <div class="col-12 col-md-6 d-flex align-items-center justify-content-md-end px-0">
              <label class="form-label fw-bold me-3 mb-0">Status:</label>
              <div class="btn-group flex-grow-1" style="max-width: 250px;">
                <button class="btn btn-secondary" type="button">
                  Select
                </button>
                <button type="button" class="btn btn-secondary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                  <span class="visually-hidden">Toggle Dropdown</span>
                </button>
               <ul class="dropdown-menu p-2">
  <li>
    <div class="form-check">
      <input class="form-check-input" type="checkbox"
        name="project[status][]" value="Completed" id="checkCompleted">
      <label class="form-check-label" for="checkCompleted">Completed</label>
    </div>
  </li>

  <li>
    <div class="form-check">
      <input class="form-check-input" type="checkbox"
        name="project[status][]" value="In Progress" id="checkInProgress">
      <label class="form-check-label" for="checkInProgress">In Progress</label>
    </div>
  </li>

  <li>
    <div class="form-check">
      <input class="form-check-input" type="checkbox"
        name="project[status][]" value="Archived" id="checkArchived">
      <label class="form-check-label" for="checkArchived">Archived</label>
    </div>
  </li>
</ul>
              </div>
            </div>

           <div class="mb-4 row g-3">
             <div class="col-12 col-md-6 d-flex align-items-center justify-content-md-end px-0">
              <label class="form-label fw-bold me-3 mb-0">TechStacks:</label>
              <div class="btn-group flex-grow-1" style="max-width: 250px;">
                <button class="btn btn-secondary" type="button">
