<% layout("./layouts/boilerplate") %>
<%
    const resume = resumeData && resumeData.resume;
    const isImage = resume && resume.type === "image";
    const isPdf =
        resume &&
        (resume.type === "pdf" || /\.pdf(\?|$)/i.test(resume.url));
%>

<div class="resume-container">

    <% if (!resume || !resume.url) { %>

        <div class="no-resume">
            <h2>No Resume Found</h2>
            <p>Resume is currently unavailable.</p>
        </div>

    <% } else { %>

        <!-- Heading -->

        <h1 class="resume-heading">My Resume</h1>


        <!-- Resume Preview -->

        <div class="resume-preview">

            <% if (isImage) { %>

                <img
                    src="<%= resume.url %>"
                    alt="My Resume"
                    class="resume-image"
                >

            <% } else if (isPdf) { %>

                <iframe
                    src="<%= resume.url %>"
                    class="resume-pdf"
                    title="My Resume"
                >
                </iframe>

            <% } else { %>

                <div class="preview-unavailable">

                    <p>Preview unavailable for this file format.</p>

                </div>

            <% } %>

        </div>


        <!-- Download Button -->

        <div class="download-container">

            <a
                href="<%= resume.url %>"
                download="Sumit_Kumar_Resume.<%= isPdf ? 'pdf' : 'jpg' %>"
                class="download-btn"
            >
                <i class="fa-solid fa-download"></i>

                Download Resume
            </a>

        </div>

    <% } %>

</div>


<style>

/* Main Container */

.resume-container {

    width: 95%;
    max-width: 1000px;

    margin: 40px auto;

    animation: fadeUp 0.6s ease;

}


/* Heading */

.resume-heading {

    text-align: center;

    font-size: 2rem;
    font-weight: 700;
      color: white;
    margin-bottom: 25px;

}


/* Resume Preview */

.resume-preview {

    width: 100%;

    display: flex;
    justify-content: center;

}


/* PDF */

.resume-pdf {

    width: 100%;
    height: 100vh;

    min-height: 1000px;

    border: 1px solid #ddd;
    border-radius: 8px;

    background: white;

}


/* Image */

.resume-image {

    display: block;

    width: 100%;
    max-width: 800px;

    height: auto;

    border-radius: 8px;

    border: 1px solid #ddd;

}


/* Download Section */

.download-container {

    display: flex;

    justify-content: center;

    margin-top: 25px;

}


/* Download Button */

.download-btn {

    display: inline-flex;

    align-items: center;

    gap: 8px;

    padding: 10px 22px;

    background: #212529;

    color: white;

    text-decoration: none;

    border-radius: 6px;

    font-size: 15px;

    font-weight: 500;

    transition:
        transform 0.2s ease,
        background 0.2s ease;

}


.download-btn:hover {

    background: #000;

    color: white;

    transform: translateY(-2px);

}


.download-btn:active {

    transform: scale(0.97);

}


/* No Resume */

.no-resume {
    text-align: center;
    margin-top: 300px;
    margin-bottom: 300px;
      color: white;
}
/* Simple Page Animation */
@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(15px);

    }

    to {

        opacity: 1;

        transform: translateY(0);

    }

}


/* Mobile */

@media (max-width: 600px) {

    .resume-container {

        width: 96%;

        margin: 25px auto;

    }


    .resume-heading {

        font-size: 1.7rem;

        margin-bottom: 18px;

    }


    .resume-pdf {

        height: 70vh;

        min-height: 450px;

    }


    .download-btn {

        width: 100%;

        justify-content: center;

    }

}
</style>

