<% layout("./layouts/boilerplate") %>

<main class="admin-dashboard">
    <section class="dashboard-panel resume-admin">
        <div class="section-heading">
            <span class="section-kicker">Admin</span>
            <h2>Manage Resume</h2>
        </div>

        <form action="/admin/uploadResume?_method=PUT"
              method="post"
              enctype="multipart/form-data">

            <label for="resumeUpload">Upload New Resume</label>

            <input
                type="file"
                id="resumeUpload"
                name="resume"
                accept=".pdf,.jpg,.jpeg,.png"
                required
            >

            <button type="submit" class="btn btn-outline-light">
                Upload Resume
            </button>
        </form>

        <div class="dashboard-actions">
            <form action="/admin/deleteResume?_method=DELETE" method="post" class="delete-form">
                <button type="submit" class="btn btn-outline-danger">
                    Delete Resume
                </button>
            </form>
        </div>
    </section>

    <section class="dashboard-panel project-admin">
        <div class="section-heading">
            <span class="section-kicker">Projects</span>
            <h2>Edit Projects</h2>
        </div>
        <div class="dashboard-primary-action">
 <form action="/admin/addProject" method="get">
                <button type="submit" class="btn admin-dashboard-add-btn">
                    Add New Project
                </button>
            </form>
        </div>
           

        <% if (allProjects && allProjects.length) { %>
            <div class="project-card-grid">
                <% allProjects.forEach((project) => { %>
                    <article class="project-admin-card">
                        <img
                            class="project-thumbnail"
                            src="<%= project.thumbnail && project.thumbnail.url ? project.thumbnail.url : '/images/default-project.jpg' %>"
                            alt="<%= project.title %> thumbnail"
                        >

                        <div class="project-card-body">
                            <h3><%= project.title %></h3>

                            <div class="project-card-actions">
                                <a href="/admin/edit/<%= project._id %>" class="btn btn-outline-light update-form">
                                    Edit Project
                                </a>

                                <form action="/admin/delete/<%= project._id %>" method="get" class="delete-form">
                                    <button type="submit" class="btn btn-outline-danger">
                                        Delete Project
                                    </button>
                                </form>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } else { %>
            <p class="empty-projects">No projects added yet.</p>
        <% } %>
    </section>
</main>

<style>
    .admin-dashboard {
        width: min(1180px, calc(100% - 32px));
        margin: 64px auto 90px;
        color: white;
    }

    .dashboard-panel {
        padding: 30px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 18px;
        background: transparent;
        box-shadow: none;
    }

    .dashboard-panel + .dashboard-panel {
        margin-top: 30px;
    }

    .admin-dashboard .section-heading {
        display: block;
        margin-bottom: 24px;
    }

    .section-kicker {
        display: block;
        margin-bottom: 8px;
        color: #4facfe;
        font-family: "Roboto Mono", monospace;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .admin-dashboard .section-heading h2 {
        margin: 0;
        color: #f8fafc;
        font-size: clamp(1.7rem, 3vw, 2.55rem);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: 0;
        white-space: normal;
    }

    .resume-admin form {
        margin-top: 15px;
    }

    .resume-admin label {
        display: block;
        margin-bottom: 10px;
        color: #dbeafe;
        font-weight: 700;
    }

    .resume-admin input {
        width: 100%;
        min-height: 46px;
        margin-bottom: 18px;
        padding: 9px 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.045);
        color: #f8fafc;
    }

    .resume-admin input::file-selector-button {
        margin-right: 14px;
        border: 0;
        border-radius: 10px;
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        color: #041014;
        font-weight: 700;
    }

    .dashboard-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid rgba(255, 255, 255, 0.14);
    }

    .dashboard-primary-action {
        display: flex;
        justify-content: flex-end;
        margin: -52px 0 26px;
    }

    .admin-dashboard-add-btn {
        border: 0;
        border-radius: 999px;
        padding: 10px 20px;
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        color: #031014;
        font-weight: 800;
        box-shadow: 0 14px 34px rgba(79, 172, 254, 0.2);
        transition: 0.25s ease;
    }

    .admin-dashboard-add-btn:hover {
        color: #031014;
        transform: translateY(-2px);
        box-shadow: 0 18px 44px rgba(79, 172, 254, 0.32);
    }

    .project-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    .project-admin-card {
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.025);
        transition: 0.25s ease;
    }

    .project-admin-card:hover {
        border-color: rgba(79, 172, 254, 0.45);
        transform: translateY(-5px);
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.24);
    }

    .project-thumbnail {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 11;
        object-fit: cover;
        background: rgba(255, 255, 255, 0.1);
    }

    .project-card-body {
        padding: 18px;
    }

    .project-card-body h3 {
        min-height: 2.6em;
        margin: 0 0 18px;
        color: #f8fafc;
        font-size: 1.12rem;
        font-weight: 800;
        line-height: 1.35;
    }

    .project-card-actions {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .project-card-actions .btn,
    .project-card-actions form,
    .project-card-actions button {
        width: 100%;
    }

    .project-card-actions .btn {
        border-radius: 999px;
        font-weight: 700;
    }

    .empty-projects {
        margin: 0;
        color: rgba(255, 255, 255, 0.72);
    }

    @media (max-width: 576px) {
        .admin-dashboard {
            width: min(100% - 20px, 1120px);
            margin: 32px auto;
        }

        .dashboard-panel {
            padding: 20px;
        }

        .dashboard-primary-action {
            justify-content: flex-start;
            margin: 0 0 22px;
        }

        .project-card-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
